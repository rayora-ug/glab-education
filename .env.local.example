# Google Apps Script Web App that backs /portal (student registration).
# See apps-script/README.md for how to get these values.
GLAB_SCRIPT_URL=
GLAB_SCRIPT_TOKEN=

# Set to "true" to hide the rest of the site and redirect every route to /portal.
# Used during the A2/B1 registration window; unset (or any other value) = normal site.
NEXT_PUBLIC_LOCKDOWN_MODE=
